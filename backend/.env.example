# MongoDB Connection
# Get your connection string from MongoDB Atlas (free tier):
# 1. Go to https://www.mongodb.com/cloud/atlas
# 2. Create a free cluster
# 3. Click "Connect" → "Connect your application"
# 4. Copy the connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/thefolio?retryWrites=true&w=majority

# JWT Secret (generate a strong random string)
# You can generate one at: https://generate-random.org/
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Port
PORT=5000