{
  "version": 2,
  "buildCommand": "npm install && cd frontend && npm install && npm run build && cd ..",
  "outputDirectory": "frontend/build",
  "functions": {
    "server.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/build/index.html"
    }
  ],
  "env": [
    "MONGO_URI",
    "JWT_SECRET"
  ]
}
